": 0.0, "block": "true"}}, {"id": 226, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "style": "slider", "inverse": "true", "fadetime": 2.0, "block": "true"}}, {"id": 227, "prop": "charslot", "attributes": {}}, {"id": 228, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "style": "slider", "inverse": "true", "fadetime": 2.0, "block": "true"}}, {"id": 229, "prop": "name", "attributes": {"content": "렌킨과 베토치키는 불길 속으로 달려갔다. 양옆에 있는 집은 활활 타오르고 있었기에, 조금이라도 방심하면 옷에까지 옮겨붙을 수 있었다."}}, {"id": 230, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4207_branch_1#10$1"}}, {"id": 231, "prop": "name", "attributes": {"content": "할머니…… 흑, 흐윽, 할머니!", "name": "베토치키"}, "figure_art": "avg_4207_branch_1#10$1"}, {"id": 232, "prop": "charslot", "attributes": {}}, {"id": 233, "prop": "name", "attributes": {"content": "렌킨도 크게 소리쳐 부르고 싶었지만, 가슴 속에 쌓여가는 무력감이 그의 목구멍을 막아, 목소리를 내기도 숨을 쉬기도 어렵게 했다."}}, {"id": 234, "prop": "name", "attributes": {"content": "그는 잘 알고 있었다. 거동이 불편한 노인에게 이렇게 거대한 불길이 의미하는 것이 무엇인지."}}, {"id": 235, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4207_branch_1#10$1"}}, {"id": 236, "prop": "name", "attributes": {"content": "서, 선생님. 저…… 선생님…… 읍…… 으읍!", "name": "베토치키"}, "figure_art": "avg_4207_branch_1#10$1"}, {"id": 237, "prop": "charslot", "attributes": {}}, {"id": 238, "prop": "name", "attributes": {"content": "검은 연기가 자욱한 갈림길에서, 베토치키는 입을 막은 채 자신을 가리키고, 다시 렌킨을 가리킨 뒤, 마지막으로 갈림길을 가리켰다."}}, {"id": 239, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1963_1#10$1"}}, {"id": 240, "prop": "name", "attributes": {"content": "안 돼…… 베토치키, 나랑 떨어져서 움직이는 건 안 돼…… 내 말 들어……", "name": "렌킨"}, "figure_art": "avg_npc_1963_1#10$1"}, {"id": 241, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4207_branch_1#10$1"}}, {"id": 242, "prop": "name", "attributes": {"content": "선생님!", "name": "베토치키"}, "figure_art": "avg_4207_branch_1#10$1"}, {"id": 243, "prop": "charslot", "attributes": {}}, {"id": 244, "prop": "name", "attributes": {"content": "얼굴이 벌겋게 달아오른 소녀의 눈에서 굵은 눈물방울이 흘러내렸다. 그녀는 두 손을 모아 기이하면서도 경건한 기도 자세를 취했다."}}, {"id": 245, "prop": "name", "attributes": {"content": "하지만 그녀가 기도하는 대상은 황제도, 유로지비도 아니었다. 그녀는 렌킨의 도움을 바랐다."}}, {"id": 246, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1963_1#3$1"}}, {"id": 247, "prop": "name", "attributes": {"content": "나는……", "name": "렌킨"}, "figure_art": "avg_npc_1963_1#3$1"}, {"id": 248, "prop": "dialog", "attributes": {}}, {"id": 249, "prop": "SoundVolume", "attributes": {"volume": 0.0, "channel": "a", "fadetime": 0.5}}, {"id": 250, "prop": "PlaySound", "attributes": {"key": "$flashback", "volume": 0.8}}, {"id": 251, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 252, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 253, "prop": "charslot", "attributes": {}}, {"id": 254, "prop": "bgeffect", "attributes": {}}, {"id": 255, "prop": "Background", "attributes": {}}, {"id": 256, "prop": "Image", "attributes": {"image": "avg_8_29", "screenadapt": "coverall", "xScale": 1.05, "yScale": 1.05, "fadetime": 0.0}}, {"id": 257, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.05, "yScaleFrom": 1.05, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 20.0, "block": "false"}}, {"id": 258, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "amount": 1.0, "keep": "true"}}, {"id": 259, "prop": "Delay", "attributes": {"time": 0.1}}, {"id": 260, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 261, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 262, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 263, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 264, "prop": "Subt