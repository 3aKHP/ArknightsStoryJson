m", "posfrom": "0,0", "posto": "300,0", "afrom": 1.0, "ato": 0.0, "duration": 0.5}}, {"id": 304, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 305, "prop": "charslot", "attributes": {}}, {"id": 306, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1963_1#7$1"}}, {"id": 308, "prop": "name", "attributes": {"content": "베토치키, 기다려!", "name": "렌킨"}, "figure_art": "avg_npc_1963_1#7$1"}, {"id": 309, "prop": "charslot", "attributes": {}}, {"id": 310, "prop": "name", "attributes": {"content": "이것으로, 나는 살육의 죄를 범했다.", "name": "호리"}, "figure_art": "avg_npc_1963_1#7$1"}, {"id": 311, "prop": "name", "attributes": {"content": "식량을 위한 것도, 깨끗한 물을 위한 것도, 따뜻한 집을 위한 것도 아니다.", "name": "호리"}, "figure_art": "avg_npc_1963_1#7$1"}, {"id": 312, "prop": "name", "attributes": {"content": "그는 중얼거리며 계속 발걸음을 옮겼고, 불길이 활활 타오르는 가옥의 문을 열어젖혔다."}}, {"id": 313, "prop": "dialog", "attributes": {}}, {"id": 314, "prop": "StopSound", "attributes": {"channel": "a", "fadetime": 2.0}}, {"id": 315, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 316, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 317, "prop": "charslot", "attributes": {}}, {"id": 318, "prop": "Background", "attributes": {}}, {"id": 319, "prop": "bgeffect", "attributes": {}}, {"id": 320, "prop": "Image", "attributes": {"image": "66_i23", "screenadapt": "coverall", "xScale": 1.05, "yScale": 1.05, "fadetime": 0.0}}, {"id": 321, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.05, "yScaleFrom": 1.05, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 20.0, "block": "false"}}, {"id": 322, "prop": "PlaySound", "attributes": {"key": "$firestorm", "volume": 1.0}}, {"id": 323, "prop": "playsound", "attributes": {"key": "$d_avg_churchfire", "loop": "true", "channel": "a", "volume": 0.0}}, {"id": 324, "prop": "SoundVolume", "attributes": {"volume": 0.7, "fadetime": 2.0, "channel": "a"}}, {"id": 325, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 326, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 327, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 328, "prop": "name", "attributes": {"content": "렌킨의 시선이 호리를 지나쳤다. 설령 불꽃이 그의 눈을 태워버린다 해도, 그가 집안의 모든 것을 지켜보는 걸 막을 수는 없었다……"}}, {"id": 329, "prop": "name", "attributes": {"content": "사납게 치솟는 불길, 불에 타 흔들거리는 기둥, 죽어가는 자의 신음을 방불케 하는 타닥거리는 소리."}}, {"id": 330, "prop": "name", "attributes": {"content": "하지만, 한 노파가 불길 한가운데에 있는 조그마한 공간에 의연하게 앉아 있었다."}}, {"id": 331, "prop": "name", "attributes": {"content": "……", "name": "노부인"}}, {"id": 332, "prop": "name", "attributes": {"content": "그녀는 남아 있는 단 하나의 의자에 앉아, 무표정하게 침묵하고 있었다. 불길은 그녀의 코앞까지 다가왔지만, 마치 보이지 않는 벽에 막힌 것처럼 다가가지 못했다."}}, {"id": 333, "prop": "name", "attributes": {"content": "그녀의 몸에는 티끌 하나 묻지 않았고, 머리카락 역시 흐트러지지 않았다. 눈을 살짝 감고 있었지만, 마치 모든 것을 보고 있는 듯했다."}}, {"id": 334, "prop": "name", "attributes": {"content": "이것으로, 나는 그들의 영혼을 정화했다.", "name": "호리"}}, {"id": 335, "prop": "dialog", "attributes": {}}, {"id": 336, "prop": "StopSound", "attributes": {"channel": "a", "fadetime": 2.0}}, {"id": 337, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 338, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 339, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 340, "prop": "charslot", "attributes": {}}, {"id": 341, "prop": "Background", "attributes": {}}, {"id": 342, "prop": "Image", "attributes": {}}, {"id": 343, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}