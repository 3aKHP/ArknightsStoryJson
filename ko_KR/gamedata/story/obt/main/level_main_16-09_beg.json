cus": "m"}}, {"id": 201, "prop": "name", "attributes": {"content": "……렌킨……", "name": "군인?"}, "figure_art": "avg_npc_1976_1#1$1"}, {"id": 202, "prop": "dialog", "attributes": {}}, {"id": 203, "prop": "Effect", "attributes": {"name": "$e_whitemask", "layer": 2.0}}, {"id": 204, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 205, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 206, "prop": "charslot", "attributes": {}}, {"id": 207, "prop": "bgeffect", "attributes": {}}, {"id": 208, "prop": "Background", "attributes": {}}, {"id": 209, "prop": "focusparam", "attributes": {}}, {"id": 210, "prop": "curtain", "attributes": {}}, {"id": 211, "prop": "name", "attributes": {"content": "당신은 눈을 감고 그 목소리를 따라 그 숲으로 돌아갔다. 국경 주둔군, 다시는 돌아올 수 없는 임무."}}, {"id": 212, "prop": "name", "attributes": {"content": "지금 당신은 그곳에 없다."}}, {"id": 213, "prop": "name", "attributes": {"content": "이겼어……", "name": "???"}}, {"id": 214, "prop": "name", "attributes": {"content": "우리가 이겼어.", "name": "???"}}, {"id": 215, "prop": "dialog", "attributes": {}}, {"id": 216, "prop": "PlaySound", "attributes": {"key": "$d_avg_atmosphere_horror", "volume": 0.0, "loop": "true", "channel": "at"}}, {"id": 217, "prop": "SoundVolume", "attributes": {"volume": 0.5, "channel": "at", "fadetime": 2.0}}, {"id": 218, "prop": "focusout", "attributes": {"type": "bg", "id": "bg_newiceforest_2", "from": 1.0, "to": 0.0, "duration": 4.0, "block": "false"}}, {"id": 219, "prop": "Background", "attributes": {"image": "66_g16_smokeonblackgroud", "screenadapt": "coverall"}}, {"id": 220, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.2, "yScaleFrom": 1.2, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 20.0, "block": "false"}}, {"id": 221, "prop": "musicvolume", "attributes": {"volume": 0.6, "fadetime": 2.0}}, {"id": 222, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 223, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 224, "prop": "name", "attributes": {"content": "떠올랐다 다시 떨어지는 순간, 당신은 저 멀리 여전히 흩어지지 않는 검은 티끌을 향해 바라보았다."}}, {"id": 225, "prop": "dialog", "attributes": {}}, {"id": 226, "prop": "StopSound", "attributes": {"channel": "at", "fadetime": 2.0}}, {"id": 227, "prop": "name", "attributes": {"content": "……", "name": "'검은 눈'"}}, {"id": 228, "prop": "name", "attributes": {"content": "검은 연기가 가늘게 넘실대는 무수한 뿌리처럼, 제복의 모든 틈새를 뚫고 나와 그것을 완전히 뒤덮기까지 탐욕스럽게 휘감고, 뒤덮고, 감쌌다."}}, {"id": 229, "prop": "name", "attributes": {"content": "검은 연기에 둘러싸인 제복은 다시 천천히 사람의 형체를 이루기 시작했다. 마치……"}}, {"id": 230, "prop": "dialog", "attributes": {}}, {"id": 231, "prop": "PlaySound", "attributes": {"key": "$d_avg_smokeconverge", "volume": 1.0}}, {"id": 232, "prop": "Image", "attributes": {"image": "avg_8_30", "screenadapt": "coverall", "xScale": 1.2, "yScale": 1.2, "fadetime": 3.0}}, {"id": 233, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.2, "yScaleFrom": 1.2, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 20.0, "block": "false"}}, {"id": 234, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 235, "prop": "name", "attributes": {"content": "죽지 않았던 것처럼."}}, {"id": 236, "prop": "dialog", "attributes": {}}, {"id": 237, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 238, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 4.0, "block": "true"}}, {"id": 239, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 240, "prop": "charslot", "attributes": {}}, {"id": 241, "prop": "Background", "attributes": {}}, {"id": 242, "prop": "Image", "attributes": {}}, {"id": 243, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}