y", "attributes": {"time": 1.0}}, {"id": 38, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 39, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 40, "prop": "name", "attributes": {"content": "검은색은 점점 다가왔다. 검은색, 검은색, 또 검은색. 모든 게 다 검은색이었고, 선명한 건 오직 피의 붉은색뿐이었다. 당신은 눈앞의 존재가 살아있는지조차 확신할 수 없었다."}}, {"id": 41, "prop": "dialog", "attributes": {}}, {"id": 42, "prop": "name", "attributes": {"content": "겁먹지 마…… 물러서지 마!", "name": "???"}}, {"id": 43, "prop": "name", "attributes": {"content": "아직 힘이 남은 사람들은 모두 일어나……", "name": "???"}}, {"id": 44, "prop": "name", "attributes": {"content": "아아!!!", "name": "광부"}}, {"id": 45, "prop": "name", "attributes": {"content": "검은색은 시체와 피바다를 헤치며 다가왔다. 땅에는 광부, 호위병 그리고 평범한 우르수스인들도 있었다."}}, {"id": 46, "prop": "name", "attributes": {"content": "끊임없는 비명은 당신에게 뒤돌아서 도망치든 아니든, 난데없이 튀어나온 그 창이 언젠가는 자신을 따라잡을 걸 깨닫게 했다."}}, {"id": 47, "prop": "name", "attributes": {"content": "당신은 무수한 시체를 관통한 창이 대지로부터 솟아올라, 지면을 거의 뒤덮는 모습을 그저 바라만 보고 있을 수밖에 없었다."}}, {"id": 48, "prop": "name", "attributes": {"content": "……", "name": "'황제의 칼날'"}}, {"id": 49, "prop": "dialog", "attributes": {}}, {"id": 50, "prop": "PlaySound", "attributes": {"key": "$d_avg_daggerslow", "volume": 1.0}}, {"id": 51, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 52, "prop": "name", "attributes": {"content": "갑자기 모든 창이 시체 더미에서 뽑혀 나와, 검은 그림자의 손안에서 다시 하나의 검으로 변했다."}}, {"id": 53, "prop": "name", "attributes": {"content": "그리고 그 정체불명의 목소리 주인은 검을 높이 치켜들고 당신을 향해 겨누었다."}}, {"id": 54, "prop": "dialog", "attributes": {}}, {"id": 55, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 56, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 57, "prop": "image", "attributes": {}}, {"id": 58, "prop": "Background", "attributes": {"image": "66_g4_miningarea_polluted", "screenadapt": "coverall"}}, {"id": 59, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_077"}}, {"id": 60, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 61, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 62, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 63, "prop": "name", "attributes": {"content": "서서 죽고 싶은 모양이군.", "name": "'황제의 칼날'"}, "figure_art": "avg_npc_077"}, {"id": 64, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 65, "prop": "name", "attributes": {"content": "아…… 아니, 나는 죽지 않아……", "name": "???"}}, {"id": 66, "prop": "name", "attributes": {"content": "여기서 죽지 않아.", "name": "???"}}, {"id": 67, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_077"}}, {"id": 68, "prop": "name", "attributes": {"content": "나쁘지 않은 소망이군.", "name": "'황제의 칼날'"}, "figure_art": "avg_npc_077"}, {"id": 69, "prop": "name", "attributes": {"content": "유감스럽지만, 이뤄질 수 없는 소망이다.", "name": "'황제의 칼날'"}, "figure_art": "avg_npc_077"}, {"id": 70, "prop": "dialog", "attributes": {}}, {"id": 71, "prop": "charslot", "attributes": {}}, {"id": 72, "prop": "PlaySound", "attributes": {"key": "$d_avg_oldman_walk", "volume": 1.0}}, {"id": 73, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1964_1#1$1", "bstart": 0.2, "bend": 0.7, "duration": 1.5, "isblock": "true"}}, {"id": 74, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 75, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_077"}}, {"id": 76, "prop": "name", "attributes": {"content": "……", "name": "'황제의 칼날'"}, "figure_art": "avg_npc_077"}, {"id": 77, "prop": "name", "attributes": {"content": "저건……?", "name": "'황제의 칼날'"}, "figure_art": "avg_npc_077"}, {"id": 78, "prop": "dialog", "attributes": {}}, {"id": 79, "prop": "charslot", "attributes": {}}, {"id": 80, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1976_1#1$1", "bstart": 0.2, "bend": 0.7, "duration": 1.5}}, {"id": 81, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1976_1#1$1", "bstart": 0.2, "bend": 0.7, "duration": 1.5, "isblock": "true"}}, {"id": 82, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 83, "prop": "charslot", "attributes": {"slot": "l", "focus": "l"}}, {"id": 84, "prop": "name", "attributes": {"content": "렌킨. 우리가 왔어!", "name": "군인?"}, "figure_art": "avg_npc_1976_1#1$1"}, {"id": 85, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 86, "prop": "name", "attributes": {"content": "렌킨……", "name": "군인?"}, "figure_art": "avg_npc_1976_1#1$1"}, {"id": 87, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 88, "prop": "name", "attributes": {"content": "너희…… 레니야, 네가 왜?", "name": "???"}}, {"id": 89, "prop": "charslot", "attributes": {"slot": "l", "focus": "l"}}, {"id": 90, "prop": "name", "attributes": {"content": "널 도와주러 왔어!", "name": "군인?"}, "figure_art": "avg_npc_1976_1#1$1"}, {"id": 91, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 92, "prop": "name", "attributes": {"content": "왔구나, 날 도우러 와줬구나! 나의 전우, 너희들도……", "name": "???"}}, {"id": 93, "prop": "name", "attributes": {"content": "함께 싸우자, 그때처럼!", "name": "???"}}, {"id": 94, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 95, "prop": "name", "attributes": {"content": "그래, 그때처럼!", "name": "군인?"}, "figure_art": "avg_npc_1976_1#1$1"}, {"id": 96, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 97, "prop": "name", "attributes": {"content": "자! 저놈을 포위해, 그때처럼! 한 명이 쓰러지면 다른 한 명이 그 자리를 메우고, 한 무리가 쓰러지면 다른 무리가 그 자리를 메운다!", "name": "???"}}, {"id": 98, "prop": "name", "attributes": {"content": "내 뒤를 따라!", "name": "???"}}, {"id": 99, "prop": "charslot", "attributes": {}}, {"id": 100, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_077"}}, {"id": 101, "prop": "name", "attributes": {"content": "어리석은……", "name": "'황제의 칼날'"}}, {"id": 102, "prop": "charslot", "attributes": {}}, {"id": 103, "prop": "name", "attributes"