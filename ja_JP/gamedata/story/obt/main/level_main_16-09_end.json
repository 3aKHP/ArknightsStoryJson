}}, {"id": 286, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 287, "prop": "name", "attributes": {"content": "うっ……！", "name": "ヴェトチキ"}, "figure_art": "avg_4207_branch_1#10$1"}, {"id": 288, "prop": "dialog", "attributes": {}}, {"id": 289, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 290, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "-230,0", "posto": "100,0", "focus": "m", "bstart": 0.2, "bend": 0.7, "afrom": 1.0, "ato": 0.0, "duration": 1.5, "isblock": "true"}}, {"id": 291, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 292, "prop": "charslot", "attributes": {}}, {"id": 293, "prop": "name", "attributes": {"content": "黒い影が二人の目の前を横切る。足を引きずりながらも、まるで何かに引き寄せられているかのように、異様に力強い足取りだった。"}}, {"id": 294, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1963_1#6$1"}}, {"id": 295, "prop": "name", "attributes": {"content": "ホーリー？　どこへ行く！？", "name": "ランキン"}, "figure_art": "avg_npc_1963_1#6$1"}, {"id": 296, "prop": "charslot", "attributes": {}}, {"id": 297, "prop": "name", "attributes": {"content": "背を丸めた影はランキンの呼びかけに反応することなく、彼を待つ火の海に向かって歩いていく。"}}, {"id": 298, "prop": "name", "attributes": {"content": "四方からの火明かりに影を払われた彼は、まるで伝説に聞く処刑場へと向かう佯狂者のように、これから炎を浴びようとしているかのようだった。"}}, {"id": 299, "prop": "dialog", "attributes": {}}, {"id": 300, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 301, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4207_branch_1#1$1", "posfrom": "-300,0", "posto": "0,0", "duration": 0.5}}, {"id": 302, "prop": "delay", "attributes": {"time": 0.3}}, {"id": 303, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "300,0", "afrom": 1.0, "ato": 0.0, "duration": 0.5}}, {"id": 304, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 305, "prop": "charslot", "attributes": {}}, {"id": 306, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1963_1#7$1"}}, {"id": 308, "prop": "name", "attributes": {"content": "ヴェトチキ、待て！", "name": "ランキン"}, "figure_art": "avg_npc_1963_1#7$1"}, {"id": 309, "prop": "charslot", "attributes": {}}, {"id": 310, "prop": "name", "attributes": {"content": "これで、俺は殺戮の罪を犯した。", "name": "ホーリー"}, "figure_art": "avg_npc_1963_1#7$1"}, {"id": 311, "prop": "name", "attributes": {"content": "食糧のためでも、清潔な水のためでも、暖かな家のためでもない。", "name": "ホーリー"}, "figure_art": "avg_npc_1963_1#7$1"}, {"id": 312, "prop": "name", "attributes": {"content": "そう呟きながら、歩みを止めることなく、燃え盛る家屋の扉を押し開ける。"}}, {"id": 313, "prop": "dialog", "attributes": {}}, {"id": 314, "prop": "StopSound", "attributes": {"channel": "a", "fadetime": 2.0}}, {"id": 315, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 316, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 317, "prop": "charslot", "attributes": {}}, {"id": 318, "prop": "Background", "attributes": {}}, {"id": 319, "prop": "bgeffect", "attributes": {}}, {"id": 320, "prop": "Image", "attributes": {"image": "66_i23", "screenadapt": "coverall", "xScale": 1.05, "yScale": 1.05, "fadetime": 0.0}}, {"id": 321, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.05, "yScaleFrom": 1.05, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 20.0, "block": "false"}}, {"id": 322, "prop": "PlaySound", "attributes": {"key": "$firestorm", "volume": 1.0}}, {"id": 323, "prop": "playsound", "attributes": {"key": "$d_avg_churchfire", "loop": "true", "channel": "a", "volume": 0.0}}, {"id": 324, "prop": "SoundVolume", "attributes": {"volume": 0.7, "fadetime": 2.0, "channel": "a"}}, {"id": 325, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 326, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 327, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 328, "prop": "name", "attributes": {"content": "ランキンの視線はホーリーを越えた先へ向けられた。たとえ炎の輝きに目を焼かれても、彼は家の中で起きた出来事すべてを見届けた――"}}, {"id": 329, "prop": "name", "attributes": {"content": "獰猛に逆巻く炎、ぐらぐらと揺れる焼け焦げた柱、死にゆく者が途切れ途切れに発する呻き声のようにパチパチと爆ぜる火の音。"}}, {"id": 330, "prop": "name", "attributes": {"content": "しかし、一人の老婦人が炎の狭間のわずかな空間に腰を下ろしていた。"}}, {"id": 331, "prop": "name", "attributes": {"content": "……", "name": "年老いた婦人"}}, {"id": 332, "prop": "name", "attributes": {"content": "彼女は唯一残された椅子の上に、無言のまま腰かけていた。目と鼻の先まで迫る炎が、まるで見えない壁があるかのように隔絶されている。"}}, {"id": 333, "prop": "name", "attributes": {"content": "その身は汚れひとつなく、髪一本すら乱れていない。わずかに閉じられた両目は、まるですべてを見通しているかのようだ。"}}, {"id": 334, "prop": "name", "attributes": {"content": "これで、奴らの魂を清めた。", "name": "ホーリー"}}, {"id": 335, "prop": "dialog", "attributes": {}}, {"id": 336, "prop": "StopSound", "attributes": {"channel": "a", "fadetime": 2.0}}, {"id": 337, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 338, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 339, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 340, "prop": "charslot", "attributes": {}}, {"id": 341, "prop": "Background", "attributes": {}}, {"id": 342, "prop": "Image", "attributes": {}}, {"id": 343, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}