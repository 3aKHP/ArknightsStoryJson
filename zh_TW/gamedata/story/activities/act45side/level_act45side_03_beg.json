{"lang": "zh_TW", "eventid": "act45side", "eventName": "無憂夢囈", "entryType": "ACTIVITY", "storyCode": "SS-3", "avgTag": "行動前", "storyName": "音樂室內的光芒", "storyInfo": "在海鈴的夢境中，海鈴剛出獄便遭到了前雇主的打手弗朗西斯的追殺，隨後她又收到了來自“老爺”的邀請，讓她加入其家族。祥子在尋找海鈴的途中遇到了弗朗西斯，發現了可疑之處。\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 2, "prop": "stopmusic", "attributes": {}}, {"id": 3, "prop": "Dialog", "attributes": {}}, {"id": 4, "prop": "Background", "attributes": {"image": "65_g10_dreamcastlestage", "screenadapt": "coverall", "block": "true"}}, {"id": 5, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 6, "prop": "playMusic", "attributes": {"intro": "$loneliness_intro", "key": "$loneliness_loop", "volume": 0.6}}, {"id": 7, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 8, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 9, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 10, "prop": "Subtitle", "attributes": {"text": "<i>大雨如淚水一般落下，我只是無垠海水中的一滴。</i>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 11, "prop": "Subtitle", "attributes": {"text": "<i>獨行的夜，不再迷茫。</i>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 12, "prop": "Subtitle", "attributes": {"text": "<i>我，毋畏恐懼。</i>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 13, "prop": "subtitle", "attributes": {}}, {"id": 14, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 15, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 16, "prop": "Dialog", "attributes": {}}, {"id": 17, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 18, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 19, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 20, "prop": "charslot", "attributes": {}}, {"id": 21, "prop": "Background", "attributes": {"image": "bg_cellroomC", "screenadapt": "coverall", "block": "true"}}, {"id": 22, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 23, "prop": "PlayMusic", "attributes": {"key": "$wasteland_loop", "volume": 0.6}}, {"id": 24, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 25, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 26, "prop": "PlaySound", "attributes": {"key": "$d_gen_dooropen", "volume": 0.4}}, {"id": 27, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 28, "prop": "name", "attributes": {"content": "犯人48038，出來。", "name": "獄警"}}, {"id": 29, "prop": "name", "attributes": {"content": "長官，請問有什麼事嗎？", "name": "激動的犯人"}}, {"id": 30, "prop": "name", "attributes": {"content": "檢查個人物品，沒有忘記帶的吧？", "name": "獄警"}}, {"id": 31, "prop": "name", "attributes": {"content": "沒有，全部都帶齊了！", "name": "激動的犯人"}}, {"id": 32, "prop": "name", "attributes": {"content": "沿著走廊往前面走，走到盡頭的那個小窗口，簽名離開就好了。", "name": "獄警"}}, {"id": 33, "prop": "name", "attributes": {"content": "好、好的，謝謝長官！", "name": "激動的犯人"}}, {"id": 34, "prop": "Dialog", "attributes": {}}, {"id": 35, "prop": "PlaySound", "attributes": {"key": "$d_avg_openftstprun", "volume": 1.0, "loop": "true", "channel": "a"}}, {"id": 36, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0, "delay": 1.5}}, {"id": 37, "prop": "StopSound", "attributes": {"channel": "a", "fadetime": 4.0}}, {"id": 38, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 39, "prop": "name", "attributes": {"content": "有力的小跑聲在長廊上迴盪。"}}, {"id": 40, "prop": "name", "attributes": {"content": "沉悶的皮靴聲則一點點向走廊的最深處靠近。"}}, {"id": 41, "prop": "Dialog", "attributes": {}}, {"id": 42, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_134", "duration": 0.7}}, {"id": 43, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 44, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_134", "focus": "m"}}, {"id": 45, "prop": "name", "attributes": {"content": "海鈴。", "name": "獄警"}, "figure_art": "avg_npc_134"}, {"id": 46, "prop": "Dialog", "attributes": {}}, {"id": 47, "prop": "charslot", "attributes": {}}, {"id": 48, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 49, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#1$3", "duration": 0.7}}, {"id": 50, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 51, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#1$3", "focus": "m"}}, {"id": 52, "prop": "name", "attributes": {"content": "在。", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#1$3"}, {"id": 53, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_134", "focus": "m"}}, {"id": 54, "prop": "name", "attributes": {"content": "滾吧，今年別讓我再看到你。", "name": "獄警"}, "figure_art": "avg_npc_134"}, {"id": 55, "prop": "Dialog", "attributes": {}}, {"id": 56, "prop": "charslot", "attributes": {}}, {"id": 57, "prop": "PlaySound", "attributes": {"key": "$d_gen_dooropen", "volume": 0.8}}, {"id": 58, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 59, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#1$3", "focus": "m"}}, {"id": 60, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 61, "prop": "PlaySound", "attributes": {"key": "$d_avg_footstep_stonestep", "volume": 0.6, "channel": "step", "loop": "false"}}, {"id": 62, "prop": "stopsound", "attributes": {"channel": "step", "fadetime": 4.0}}, {"id": 63, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 64, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 65, "prop": "name", "attributes": {"content": "海鈴熟練地拿起自己的琴盒，慢悠悠地走出了監獄。"}}, {"id": 66, "prop": "Dialog", "attributes": {}}, {"id": 67, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 68, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 69, "prop": "charslot", "attributes": {}}, {"id": 70, "prop": "Background", "attributes": {"image": "33_g6_newtown_street", "screenadapt": "coverall", "block": "true"}}, {"id": 71, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 72, "prop": "PlaySound", "attributes": {"key": "$d_avg_rainlight_loop", "volume": 0.0, "loop": "true", "channel": "c"}}, {"id": 73, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "c", "fadetime": 2.0}}, {"id": 74, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 75, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 76, "prop": "name", "attributes": {"content": "敘拉古還是和從前一樣，用連綿的小雨迎接她的回歸。"}}, {"id": 77, "prop": "Dialog", "attributes": {}}, {"id": 78, "prop": "stopsound", "attributes": {"channel": "c", "fadetime": 3.0}}, {"id": 79, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 80, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 81, "prop": "charslot", "attributes": {}}, {"id": 82, "prop": "Background", "attributes": {"image": "33_g10_smallrestaurant", "screenadapt": "coverall", "block": "true"}}, {"id": 83, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 84, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 85, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 86, "prop": "PlaySound", "attributes": {"key": "$d_avg_crowdrun", "volume": 0.8}}, {"id": 87, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_698_1#1$1", "duration": 1.0}}, {"id": 88, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_699_1#1$1", "duration": 1.0}}, {"id": 89, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 90, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_698_1#1$1", "focus": "l"}}, {"id": 91, "prop": "name", "attributes": {"content": "這條街，還有前後兩條街，每家店都派人盯著，絕對不能讓她跑了！", "name": "帶頭的打手"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 92, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_699_1#1$1", "focus": "r"}}, {"id": 93, "prop": "name", "attributes": {"content": "是！", "name": "謹慎的打手"}, "figure_art": "avg_npc_699_1#1$1"}, {"id": 94, "prop": "Dialog", "attributes": {}}, {"id": 95, "prop": "charslot", "attributes": {}}, {"id": 96, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 97, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop", "volume": 1.0}}, {"id": 98, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_699_1#1$1", "duration": 0.5}}, {"id": 99, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 100, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_699_1#1$1", "focus": "m"}}, {"id": 101, "prop": "name", "attributes": {"content": "大哥，北街那邊傳來消息，她朝這邊過來了！", "name": "慌張的打手"}, "figure_art": "avg_npc_699_1#1$1"}, {"id": 102, "prop": "charslot", "attributes": {}}, {"id": 103, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_698_1#1$1", "focus": "r"}}, {"id": 104, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_699_1#1$1", "focus": "r"}}, {"id": 105, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_699_1#1$1", "focus": "r"}}, {"id": 106, "prop": "name", "attributes": {"content": "給我盯著她，別讓她跑了！", "name": "帶頭的打手"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 107, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_699_1#1$1", "focus": "l"}}, {"id": 108, "prop": "name", "attributes": {"content": "她……她好像沒有要躲的意思。", "name": "慌張的打手"}, "figure_art": "avg_npc_699_1#1$1"}, {"id": 109, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_698_1#1$1", "focus": "r"}}, {"id": 110, "prop": "name", "attributes": {"content": "……讓其他人都過來集合！", "name": "帶頭的打手"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 111, "prop": "Dialog", "attributes": {}}, {"id": 112, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 113, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 114, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 115, "prop": "charslot", "attributes": {}}, {"id": 116, "prop": "Background", "attributes": {"image": "33_g2_srcalley", "screenadapt": "coverall", "block": "true"}}, {"id": 117, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 118, "prop": "PlaySound", "attributes": {"key": "$d_avg_rainlight_loop", "volume": 0.0, "loop": "true", "channel": "d"}}, {"id": 119, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "d", "fadetime": 2.0}}, {"id": 120, "prop": "playMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.6}}, {"id": 121, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 122, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 123, "prop": "name", "attributes": {"content": "狹窄的胡同裡，一群兇神惡煞的打手，正將提著琴盒的少女團團圍住。"}}, {"id": 124, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 125, "prop": "name", "attributes": {"content": "又見面了……海鈴。", "name": "帶頭的打手"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 126, "prop": "name", "attributes": {"content": "呵，我一開始還在想，你這種高手，怎麼沒有一個家族把你納入麾下。", "name": "帶頭的打手"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 127, "prop": "name", "attributes": {"content": "我們家族遭逢變故後，四處打聽，才知道原來你是個臭名昭著的“叛徒”。", "name": "帶頭的打手"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 128, "prop": "name", "attributes": {"content": "你前後換過十幾個名字，在各個家族間幫人做事。", "name": "帶頭的打手"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 129, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#9$3", "focus": "m"}}, {"id": 130, "prop": "name", "attributes": {"content": "我們的合約裡沒有寫我不能幫別人做事。", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#9$3"}, {"id": 131, "prop": "name", "attributes": {"content": "而且我早就說過——我只是拿人錢財，替人消災。", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#9$3"}, {"id": 132, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 133, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 12.0, "ystrength": 15.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 134, "prop": "name", "attributes": {"content": "所以你就把我們的機密告訴了敵對陣營？！", "name": "帶頭的打手"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 135, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "m"}}, {"id": 136, "prop": "name", "attributes": {"content": "……我不懂你在說什麼。", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#12$3"}, {"id": 137, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 138, "prop": "name", "attributes": {"content": "*哥倫比亞粗口*，別裝傻了！自從你來過之後，我們的人就不斷遭到暗算！", "name": "帶頭的打手"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 139, "prop": "name", "attributes": {"content": "虧我和老大當時那麼信任你，還邀請你加入我們！", "name": "帶頭的打手"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 140, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "m"}}, {"id": 141, "prop": "name", "attributes": {"content": "弗朗西斯，我不記得我有做過什麼對不起你們的事……", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#7$3"}, {"id": 142, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 143, "prop": "name", "attributes": {"content": "哼，是你虧欠的人實在太多，想都想不起來了吧？！", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 144, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 145, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 146, "prop": "name", "attributes": {"content": "老大死了，大家都死了，幾百個人現在只剩我們十幾個了！", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 147, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "m"}}, {"id": 148, "prop": "name", "attributes": {"content": "……什麼意思？", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#7$3"}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 150, "prop": "name", "attributes": {"content": "我們一群兄弟好不容易從哥倫比亞漂泊到這個鬼地方，結果全被你害死了！", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 151, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "m"}}, {"id": 152, "prop": "name", "attributes": {"content": "我……", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#7$3"}, {"id": 153, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_699_1#1$1", "focus": "m"}}, {"id": 154, "prop": "name", "attributes": {"content": "不要跟她講這麼多廢話了，我們這麼多人在這裡，今天一定要好好修理她！", "name": "憤怒的打手"}, "figure_art": "avg_npc_699_1#1$1"}, {"id": 155, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "m"}}, {"id": 156, "prop": "name", "attributes": {"content": "我不想和你們起衝突……", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#12$3"}, {"id": 157, "prop": "Dialog", "attributes": {}}, {"id": 158, "prop": "charslot", "attributes": {}}, {"id": 159, "prop": "name", "attributes": {"content": "雖然海鈴努力想要透過言語平息衝突，但對方逼近的腳步完全沒有停下來——"}}, {"id": 160, "prop": "name", "attributes": {"content": "她不得不放下拿在手上的琴盒。"}}, {"id": 161, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 162, "prop": "name", "attributes": {"content": "所有人……跟我上！", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 163, "prop": "Dialog", "attributes": {}}, {"id": 164, "prop": "PlaySound", "attributes": {"key": "$d_avg_swordexsheath", "volume": 1.0}}, {"id": 165, "prop": "PlaySound", "attributes": {"key": "$d_avg_attack_ready", "volume": 0.6, "delay": 0.7}}, {"id": 166, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 167, "prop": "Dialog", "attributes": {}}, {"id": 168, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 169, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 170, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 171, "prop": "charslot", "attributes": {}}, {"id": 172, "prop": "Image", "attributes": {"image": "cg_rainsplash", "screenadapt": "coverall", "fadetime": 0.0, "block": "true"}}, {"id": 173, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 174, "prop": "PlaySound", "attributes": {"key": "$d_avg_shallowswalk", "volume": 1.0, "loop": "true", "channel": "s"}}, {"id": 175, "prop": "StopSound", "attributes": {"channel": "s", "fadetime": 2.5}}, {"id": 176, "prop": "PlayMusic", "attributes": {"intro": "$mist_intro", "key": "$mist_loop", "volume": 0.6}}, {"id": 177, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 178, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 179, "prop": "name", "attributes": {"content": "小姐，不要再往前走了。", "name": "好心的老婦人"}}, {"id": 180, "prop": "name", "attributes": {"content": "那邊剛剛發生了一點事，你一個人過去很危險，還是繞路吧。", "name": "好心的老婦人"}}, {"id": 181, "prop": "name", "attributes": {"content": "……謝謝提醒。", "name": "戴著帽子的少女"}}, {"id": 182, "prop": "name", "attributes": {"content": "少女並沒有理會路人的勸告，而是朝她說的方向繼續走去。"}}, {"id": 183, "prop": "Dialog", "attributes": {}}, {"id": 184, "prop": "PlaySound", "attributes": {"key": "$d_avg_shallowswalk", "volume": 1.0}}, {"id": 185, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 186, "prop": "Dialog", "attributes": {}}, {"id": 187, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 188, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 189, "prop": "image", "attributes": {}}, {"id": 190, "prop": "charslot", "attributes": {}}, {"id": 191, "prop": "Background", "attributes": {"image": "33_g2_srcalley", "screenadapt": "coverall", "block": "true"}}, {"id": 192, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 193, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 194, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 195, "prop": "name", "attributes": {"content": "雨淅淅瀝瀝地下著，沖刷著敘拉古的一切。"}}, {"id": 196, "prop": "name", "attributes": {"content": "少女走進小巷，這裡乾乾淨淨，彷彿是剛建好一樣，一塵不染。"}}, {"id": 197, "prop": "name", "attributes": {"content": "敘拉古的清潔工總是這麼專業。"}}, {"id": 198, "prop": "name", "attributes": {"content": "潮濕的空氣中，聞不到一絲血腥味。"}}, {"id": 199, "prop": "Dialog", "attributes": {}}, {"id": 200, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$3", "duration": 1.0}}, {"id": 201, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 202, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$3", "focus": "m"}}, {"id": 203, "prop": "name", "attributes": {"content": "……", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#2$3"}, {"id": 204, "prop": "name", "attributes": {"content": "海鈴……你在哪裡？", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#2$3"}, {"id": 205, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$3", "focus": "n"}}, {"id": 206, "prop": "name", "attributes": {"content": "你在……找海鈴嗎？", "name": "？？？"}}, {"id": 207, "prop": "Dialog", "attributes": {}}, {"id": 208, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$3", "focus": "m"}}, {"id": 209, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 210, "prop": "Dialog", "attributes": {}}, {"id": 211, "prop": "charslot", "attributes": {}}, {"id": 212, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 213, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "duration": 1.0}}, {"id": 214, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 215, "prop": "Dialog", "attributes": {}}, {"id": 216, "prop": "StopSound", "attributes": {"channel": "d", "fadetime": 2.0}}, {"id": 217, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 218, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 219, "prop": "charslot", "attributes": {}}, {"id": 220, "prop": "Background", "attributes": {"image": "33_g11_mansionhall", "screenadapt": "coverall", "block": "true"}}, {"id": 221, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 222, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 223, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 224, "prop": "name", "attributes": {"content": "一座娛樂場裡的撞球間。沒有人會想到，有人把這裡當成自己的家。"}}, {"id": 225, "prop": "name", "attributes": {"content": "幾個紙箱簡單地拼成了一張床，最基本的生活用品全被塞進了速食店贈送的袋子裡。"}}, {"id": 226, "prop": "Dialog", "attributes": {}}, {"id": 227, "prop": "PlaySound", "attributes": {"key": "$d_avg_openenvelope_slow", "volume": 1.0}}, {"id": 228, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 229, "prop": "PlaySound", "attributes": {"key": "$d_avg_coin"}}, {"id": 230, "prop": "PlaySound", "attributes": {"key": "$d_avg_coin", "loop": "false", "channel": "coin2", "delay": 0.6}}, {"id": 231, "prop": "name", "attributes": {"content": "撞球桌上擺滿了信封，裡面裝著海鈴的酬勞。"}}, {"id": 232, "prop": "name", "attributes": {"content": "海鈴一一拆開這些信封，將裡面的金幣隨手丟在桌上，一枚枚印刻著“家族”、“秩序”的金幣很快堆成了一座小山。"}}, {"id": 233, "prop": "name", "attributes": {"content": "這些金幣就這樣被隨意地放在毫無保護的地方，就算不見了，她也完全不會心疼。"}}, {"id": 234, "prop": "Dialog", "attributes": {}}, {"id": 235, "prop": "PlaySound", "attributes": {"key": "$d_avg_papertear", "volume": 1.0}}, {"id": 236, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 237, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "m"}}, {"id": 238, "prop": "name", "attributes": {"content": "……嗯？", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#7$3"}, {"id": 239, "prop": "Dialog", "attributes": {}}, {"id": 240, "prop": "charslot", "attributes": {}}, {"id": 241, "prop": "name", "attributes": {"content": "海鈴再次確認了一遍——這封信裡什麼都沒有。"}}, {"id": 242, "prop": "name", "attributes": {"content": "她將信封翻了過來，上面印著一枚家族印記，還有一個寄件地址。"}}, {"id": 243, "prop": "Dialog", "attributes": {}}, {"id": 244, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 245, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 246, "prop": "charslot", "attributes": {}}, {"id": 247, "prop": "Background", "attributes": {"image": "33_g7_reception", "screenadapt": "coverall", "block": "true"}}, {"id": 248, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 249, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 250, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 251, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_699_1#1$1", "focus": "m"}}, {"id": 252, "prop": "name", "attributes": {"content": "老爺，她來了。", "name": "嚴肅的打手"}, "figure_art": "avg_npc_699_1#1$1"}, {"id": 253, "prop": "Dialog", "attributes": {}}, {"id": 254, "prop": "charslot", "attributes": {}}, {"id": 255, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 256, "prop": "PlaySound", "attributes": {"key": "$d_avg_walk_stage", "volume": 1.0, "loop": "false", "channel": "nw"}}, {"id": 257, "prop": "stopsound", "attributes": {"fadetime": 2.0, "channel": "nw"}}, {"id": 258, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#1$3", "duration": 1.0}}, {"id": 259, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 260, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#1$3", "focus": "n"}}, {"id": 261, "prop": "name", "attributes": {"content": "監獄裡的那些人，沒有找你麻煩吧？", "name": "蒼老的聲音"}}, {"id": 262, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#11$3", "focus": "m"}}, {"id": 263, "prop": "name", "attributes": {"content": "都認識多久了，更何況，他們都知道我背後的雇主是誰，何必自找麻煩。", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#11$3"}, {"id": 264, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "m"}}, {"id": 265, "prop": "name", "attributes": {"content": "不過老爺特地把我叫來，恐怕不只是為了問我這種小事吧？", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#12$3"}, {"id": 266, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "n"}}, {"id": 267, "prop": "name", "attributes": {"content": "呵呵，就只是單純關心一下合作夥伴。", "name": "蒼老的聲音"}}, {"id": 268, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "m"}}, {"id": 269, "prop": "name", "attributes": {"content": "老爺，我們什麼時候變成合作夥伴了？", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#12$3"}, {"id": 270, "prop": "name", "attributes": {"content": "我們之前簽合約時，你甚至不願意以你家族的名義委託我。", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#12$3"}, {"id": 271, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "n"}}, {"id": 272, "prop": "name", "attributes": {"content": "既然想成為“合作夥伴”，從現在起當然要坦誠相見——", "name": "蒼老的聲音"}}, {"id": 273, "prop": "name", "attributes": {"content": "海鈴，我想和你做筆長期生意。", "name": "蒼老的聲音"}}, {"id": 274, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "m"}}, {"id": 275, "prop": "name", "attributes": {"content": "什麼生意必須當面談？", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#7$3"}, {"id": 276, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "n"}}, {"id": 277, "prop": "name", "attributes": {"content": "我想——邀請你加入我的家族。", "name": "蒼老的聲音"}}, {"id": 278, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#6$3", "focus": "m"}}, {"id": 279, "prop": "name", "attributes": {"content": "……", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#6$3"}, {"id": 280, "prop": "name", "attributes": {"content": "你說……什麼？", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#6$3"}, {"id": 281, "prop": "Dialog", "attributes": {}}, {"id": 282, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 283, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 284, "prop": "charslot", "attributes": {}}, {"id": 285, "prop": "Background", "attributes": {"image": "33_g11_mansionhall", "screenadapt": "coverall", "block": "true"}}, {"id": 286, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 287, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 288, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 289, "prop": "PlaySound", "attributes": {"key": "$d_avg_open_door", "volume": 0.6}}, {"id": 290, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 291, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 292, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "duration": 1.0}}, {"id": 293, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 294, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 295, "prop": "name", "attributes": {"content": "裡面沒人。", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 296, "prop": "Dialog", "attributes": {}}, {"id": 297, "prop": "charslot", "attributes": {}}, {"id": 298, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop", "volume": 1.0}}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "duration": 0.5}}, {"id": 300, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 301, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 302, "prop": "name", "attributes": {"content": "你明明那麼怕她，為什麼還要跟過來？", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 303, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 304, "prop": "name", "attributes": {"content": "你不是家族成員，當然不懂！我必須……幫大家報仇雪恨！", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 306, "prop": "name", "attributes": {"content": "你們和海鈴之間到底發生過什麼事，她那麼不可饒恕嗎？", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 308, "prop": "name", "attributes": {"content": "如果你經歷過這種“背叛”，一定也不會原諒她……", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 309, "prop": "name", "attributes": {"content": "我們家族大部分的成員都是從哥倫比亞拓荒區逃到這裡的普通人，缺少人脈和背景，所以常常被當地的幫派找碴。", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 310, "prop": "name", "attributes": {"content": "這種情況持續了很多年，直到有一天，老大花重金請來了一個打手。", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 311, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 312, "prop": "name", "attributes": {"content": "那個人是海鈴？", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 313, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 314, "prop": "name", "attributes": {"content": "嗯。僱傭她以後，我們度過了很長一段時間的安穩日子。", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 315, "prop": "name", "attributes": {"content": "那段日子真的很美好，再也不用擔心據點突然被人偷襲，也不用擔心有人上門來找麻煩……", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 316, "prop": "name", "attributes": {"content": "但我們邀請她加入我們家族時，她卻拒絕了，而且第二天她整個人還直接消失了。", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 317, "prop": "name", "attributes": {"content": "正當我們覺得疑惑的時候，不知道是誰引來跟我們敵對陣營的打手，偷襲了我們的據點。", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 318, "prop": "name", "attributes": {"content": "我至今都不願回想那個場面……實在太慘了！", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 319, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 320, "prop": "name", "attributes": {"content": "你覺得是海鈴出賣了你們？", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 321, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 322, "prop": "name", "attributes": {"content": "除了她還有可能是誰？哪有這麼巧的事情？！", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 323, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#10$2", "focus": "m"}}, {"id": 324, "prop": "name", "attributes": {"content": "……我不相信海鈴會做出這種背信棄義的事。", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 325, "prop": "name", "attributes": {"content": "我認識的海鈴和你說的一樣，能力強大，令人安心。", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 326, "prop": "name", "attributes": {"content": "而且會對自己加入的組織盡職盡責。", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 327, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 328, "prop": "name", "attributes": {"content": "可是，事實就擺在我的面前……", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 329, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 330, "prop": "name", "attributes": {"content": "你有在那群偷襲你們的人當中看見她的身影嗎？", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 331, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 332, "prop": "name", "attributes": {"content": "……沒有。", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 333, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 334, "prop": "name", "attributes": {"content": "那你還記得那些偷襲者的面貌嗎？", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 335, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 336, "prop": "name", "attributes": {"content": "一輩子都忘不了。", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 337, "prop": "Dialog", "attributes": {}}, {"id": 338, "prop": "charslot", "attributes": {}}, {"id": 339, "prop": "name", "attributes": {"content": "祥子深吸了一口氣，將手伸向口袋裡的防身武器。"}}, {"id": 340, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 341, "prop": "name", "attributes": {"content": "如果……是有人故意挑撥你們呢？", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 342, "prop": "name", "attributes": {"content": "如果……是有人一直在監視海鈴呢？", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 343, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 344, "prop": "name", "attributes": {"content": "……你這是什麼意思？", "name": "弗朗西斯"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 345, "prop": "Dialog", "attributes": {}}, {"id": 346, "prop": "charslot", "attributes": {}}, {"id": 347, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 348, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 349, "prop": "PlaySound", "attributes": {"key": "$d_avg_opencabinet", "volume": 0.8}}, {"id": 350, "prop": "PlaySound", "attributes": {"key": "$d_avg_open_drawer", "volume": 1.0, "delay": 0.3}}, {"id": 351, "prop": "PlaySound", "attributes": {"key": "$d_avg_opencabinet", "volume": 1.0, "loop": "false", "channel": "k", "delay": 0.5}}, {"id": 352, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 353, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 354, "prop": "name", "attributes": {"content": "弗朗西斯還沒反應過來，四周的櫃門突然全部被推開。"}}, {"id": 355, "prop": "name", "attributes": {"content": "每個櫃子裡都站著一個身形魁梧的打手，他們手裡拿著武器，一齊指向房間中央的兩人。"}}, {"id": 356, "prop": "Dialog", "attributes": {}}, {"id": 357, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_699_1#1$1", "duration": 1.0}}, {"id": 358, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_699_1#1$1", "duration": 1.0}}, {"id": 359, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 360, "prop": "playsound", "attributes": {"key": "$d_avg_gunequip", "volume": 0.7}}, {"id": 361, "prop": "PlaySound", "attributes": {"key": "$d_avg_gunload", "volume": 0.9, "delay": 0.2}}, {"id": 362, "prop": "PlaySound", "attributes": {"key": "$shotgunreload", "volume": 1.0, "delay": 0.4}}, {"id": 363, "prop": "playsound", "attributes": {"key": "$d_avg_gunequip", "channel": "1", "volume": 0.3}}, {"id": 364, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 365, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_699_1#1$1", "focus": "all"}}, {"id": 366, "prop": "name", "attributes": {"content": "不准動。", "name": "神秘的打手們"}}, {"id": 367, "prop": "Dialog", "attributes": {}}, {"id": 368, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 369, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 370, "prop": "charslot", "attributes": {}}, {"id": 371, "prop": "Image", "attributes": {}}, {"id": 372, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}