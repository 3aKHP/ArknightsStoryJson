"31_g3_mini12_farmland", "screenadapt": "coverall", "block": "true"}}, {"id": 80, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 81, "prop": "PlayMusic", "attributes": {"key": "$saferoom_loop", "volume": 0.6}}, {"id": 82, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 83, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 84, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#7$1", "focus": "m"}}, {"id": 85, "prop": "name", "attributes": {"content": "現在有沒有好一點……？", "name": "母親"}, "figure_art": "avg_npc_1941_1#7$1"}, {"id": 86, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1940_1#3$1", "focus": "m"}}, {"id": 87, "prop": "name", "attributes": {"content": "不好意思，是我沒控制住，做太多菜了……", "name": "父親"}, "figure_art": "avg_npc_1940_1#3$1"}, {"id": 88, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#3$1", "focus": "m"}}, {"id": 89, "prop": "name", "attributes": {"content": "真是的，你爸爸就是這樣……", "name": "母親"}, "figure_art": "avg_npc_1941_1#3$1"}, {"id": 90, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#1$1", "focus": "m"}}, {"id": 91, "prop": "name", "attributes": {"content": "不過這就是他的行事風格，大部分的時候也蠻可愛的。", "name": "母親"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 92, "prop": "name", "attributes": {"content": "祥子，你會原諒他的吧？", "name": "母親"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 93, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#10$2", "focus": "m"}}, {"id": 94, "prop": "name", "attributes": {"content": "我……", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 95, "prop": "dialog", "attributes": {}}, {"id": 96, "prop": "charslot", "attributes": {}}, {"id": 97, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 98, "prop": "Subtitle", "attributes": {"text": "我……真的能原諒他嗎？", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 99, "prop": "Subtitle", "attributes": {"text": "那個和他有著相同面貌的男人，曾無數次地傷透我的心。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 100, "prop": "subtitle", "attributes": {}}, {"id": 101, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 102, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 103, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#5$1", "focus": "m"}}, {"id": 104, "prop": "name", "attributes": {"content": "他真的很愛你哦。", "name": "母親"}, "figure_art": "avg_npc_1941_1#5$1"}, {"id": 105, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#6$2", "focus": "m"}}, {"id": 106, "prop": "name", "attributes": {"content": "——！", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 107, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#6$1", "focus": "m"}}, {"id": 108, "prop": "name", "attributes": {"content": "我也一樣。", "name": "母親"}, "figure_art": "avg_npc_1941_1#6$1"}, {"id": 109, "prop": "name", "attributes": {"content": "我真的很愛你們。", "name": "母親"}, "figure_art": "avg_npc_1941_1#6$1"}, {"id": 110, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#6$2", "focus": "m"}}, {"id": 111, "prop": "name", "attributes": {"content": "媽媽，怎麼突然這麼說……", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 112, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#1$1", "focus": "m"}}, {"id": 113, "prop": "name", "attributes": {"content": "你出遠門的這段時間，我開始越來越頻繁地翻相簿了。", "name": "母親"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 114, "prop": "name", "attributes": {"content": "從你出生時的照片，翻到一歲、兩歲、三歲……", "name": "母親"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 115, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#6$2", "focus": "m"}}, {"id": 116, "prop": "name", "attributes": {"content": "難道都不是我嗎？", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 117, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#1$1", "focus": "m"}}, {"id": 118, "prop": "name", "attributes": {"content": "沒有哦。在父母的眼中，孩子永遠是最重要、最特殊的存在哦。", "name": "母親"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 119, "prop": "name", "attributes": {"content": "你剛出生的時候，手掌只有我的一半不到。", "name": "母親"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 120, "prop": "name", "attributes": {"content": "但現在你看，已經比我的手還大一點點啦。", "name": "母親"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 121, "prop": "dialog", "attributes": {}}, {"id": 122, "prop": "charslot", "attributes": {}}, {"id": 123, "prop": "name", "attributes": {"content": "母親拉起祥子的手，將兩人的掌心慢慢對齊。"}}, {"id": 124, "prop": "name", "attributes": {"content": "不知為何，祥子用五指緊緊地扣住了媽媽的手。"}}, {"id": 125, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#13$2", "focus": "m"}}, {"id": 126, "prop": "name", "attributes": {"content": "媽媽，你的手好溫暖……", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#13$2"}, {"id": 127, "prop": "dialog", "attributes": {}}, {"id": 128, "prop": "charslot", "attributes": {}}, {"id": 129, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 130, "prop": "Subtitle", "attributes": {"text": "這就是媽媽手心的溫度嗎……", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 131, "prop": "Subtitle", "attributes": {"text": "這一切，是真實的嗎？我享受的這一切，是合理的嗎？", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 132, "prop": "Subtitle", "attributes": {"text": "為什麼會如此溫暖，卻又如此哀傷？", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 133, "prop": "subtitle", "attributes": {}}, {"id": 134, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 135, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 136, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#6$1", "focus": "m"}}, {"id": 137, "prop": "name", "attributes": {"content": "嗯，我在喔。", "name": "母親"}, "figure_art": "avg_npc_1941_1#6$1"}, {"id": 138, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#8$2", "focus": "m"}}, {"id": 139, "prop": "name", "attributes": {"content": "媽媽……", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#8$2"}, {"id": 140, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#5$1", "focus": "m"}}, {"id": 141, "prop": "name", "attributes": {"content": "想哭也沒關係哦。你以前哭的時候，我也是這樣安慰你的。", "name": "母親"}, "figure_art": "avg_npc_1941_1#5$1"}, {"id": 142, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#8$2", "focus": "m"}}, {"id": 143, "prop": "name", "attributes": {"content": "欸……我以前有那麼愛哭嗎？", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#8$2"}, {"id": 144, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#5$1", "focus": "m"}}, {"id": 145, "prop": "name", "attributes": {"content": "在你很小很小的時候吧，那個時候祥子常常為了一顆糖果又哭又鬧。", "name": "母親"}, "figure_art": "avg_npc_1941_1#5$1"}, {"id": 146, "prop": "name", "attributes": {"content": "雖然祥子現在是個堅強的孩子，但那個時候真的是一個愛哭鬼呢。", "name": "母親"}, "figure_art": "avg_npc_1941_1#5$1"}, {"id": 147, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#10$2", "focus": "m"}}, {"id": 148, "prop": "name", "attributes": {"content": "是、是嗎，我一點都不記得了……", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#6$1", "focus": "m"}}, {"id": 150, "prop": "name", "attributes": {"content": "哈哈哈哈哈，媽媽沒有騙你哦。", "name": "母親"}, "figure_art": "avg_npc_1941_1#6$1"}, {"id": 151, "prop": "dialog", "attributes": {}}, {"id": 152, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#10$2", "focus": "m"}}, {"id": 153, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 154, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#1$2", "focus": "m"}}, {"id": 155, "prop": "name", "attributes": {"content": "那……媽媽，你還記得我的高中入學典禮嗎？", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#1$2"}, {"id": 156, "prop": "dialog", "attributes": {}}, {"id": 157, "prop": "charslot", "attributes": {}}, {"id": 158, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 159, "prop": "Subtitle", "attributes": {"text": "國三那年，母親因病急逝。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 160, "prop": "Subtitle", "attributes": {"text": "未曾留痕的記憶，或者從未發生的事情。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 161, "prop": "Subtitle", "attributes": {"text": "此刻卻想要最美好的答案。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 162, "prop": "Subtitle", "attributes": {"text": "說服自己，創造最美好的回憶，相信最美好的夢境。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 163, "prop": "subtitle", "attributes": {}}, {"id": 164, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 165, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 166, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#6$1", "focus": "m"}}, {"id": 167, "prop": "name", "attributes": {"content": "當然啊，我還記得那天你穿著制服，我們一家還在校門口合照呢。", "name": "母親"}, "figure_art": "avg_npc_1941_1#6$1"}, {"id": 168, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#13$2", "focus": "m"}}, {"id": 169, "prop": "name", "attributes": {"content": "好像是呢……真令人懷念。", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#13$2"}, {"id": 170, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#1$2", "focus": "m"}}, {"id": 171, "prop": "name", "attributes": {"content": "我們以前，還經歷過哪些事？媽媽……我想聽你講，關於我們的回憶。", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#1$2"}, {"id": 172, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#5$1", "focus": "m"}}, {"id": 173, "prop": "name", "attributes": {"content": "祥子，你是不是離開家裡太久了？怎麼今天這麼黏人？", "name": "母親"}, "figure_art": "avg_npc_1941_1#5$1"}, {"id": 174, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$2", "focus": "m"}}, {"id": 175, "prop": "name", "attributes": {"content": "家……", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#2$2"}, {"id": 176, "prop": "dialog", "attributes": {}}, {"id": 177, "prop": "charslot", "attributes": {}}, {"id": 178, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 179, "prop": "Subtitle", "attributes": {"text": "“家”這個名詞，是從什麼時候開始，變得這麼陌生的呢？", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 180, "prop": "subtitle", "attributes": {}}, {"id": 181, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 182, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 183, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#1$1", "focus": "m"}}, {"id": 184, "prop": "name", "attributes": {"content": "嗯……既然你想聽，那我就再回憶一下吧。", "name": "母親"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 185, "prop": "name", "attributes": {"content": "從什麼時候開始講呢？", "name": "母親"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 186, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#1$2", "focus": "m"}}, {"id": 187, "prop": "name", "attributes": {"content": "從我出生的時候開始吧，我想一直聽下去。", "name": "豐川祥子"}, "figure_art": "avg_4182_oblvns_1#1$2"}, {"id": 188, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#1$1", "focus": "m"}}, {"id": 189, "prop": "name", "attributes": {"content": "好，那就從你的出生開始講吧……", "name": "母親"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 190, "prop": "dialog", "attributes": {}}, {"id": 191, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 192, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 193, "prop": "name", "attributes": {"content": "就這樣，在田間小路上，母女二人肩並著肩，以不快不慢的速度走著，彷彿可以一直這樣走下去。"}}, {"id": 194, "prop": "name", "attributes": {"content": "就像她們最開始的那段美好時光一樣，不慌不忙，沒有戛然而止。"}}, {"id": 195, "prop": "name", "attributes": {"content": "她們的手，就像最開始連接兩人的那根臍帶。"}}, {"id": 196, "prop": "dialog", "attributes": {}}, {"id": 197, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 198, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 199, "prop": "name", "attributes": {"content": "祥子——", "name": "？？？"}}, {"id": 200, "prop": "dialog", "attributes": {}}, {"id": 201, "prop": "CameraShake", "attributes": {"xstrength": 5.0, "ystrength": 5.0, "vibrato": 20.0, "randomness": 90.0, "fadeout": "false", "block": "false"}}, {"id": 202, "prop": "PlaySound", "attributes": {"key": "$d_avg_enginerun", "volume": 0.0, "loop": "true", "channel": "bse"}}, {"id": 203, "prop": "SoundVolume", "attributes": {"channel": "bse", "volume": 0.3, "fadetime": 2.5}}, {"id": 204, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 205, "prop": "name", "attributes": {"content": "你找到回家的路了啊！", "name": "紅豆"}}, {"id": 206, "prop": "name", "attributes": {"content": "紅豆小姐，這台車好像故障了，請你快點放我下來！", "name": "愛麗絲"}}, {"id": 207, "prop": "name", "attributes": {"content": "我看看……怎、怎麼和在羅德島上學的操作方法不一樣啊？！", "name": "紅豆"}}, {"id": 208, "prop": "name", "attributes": {"content": "不行不行，已經停不下來了！", "name": "紅豆"}}, {"id": 209, "prop": "name", "attributes": {"content": "要撞上了——", "name": "愛麗絲"}}, {"id": 210, "prop": "name", "attributes": {"content": "祥子，你們快點閃開——！", "name": "貝娜"}}, {"id": 211, "prop": "Dialog", "attributes": {}}, {"id": 212, "prop": "StopSound", "attributes": {"channel": "bse", "fadetime": 2.0}}, {"id": 213, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 214, "prop": "CameraShake", "attributes": {"duration": 0.1, "xstrength": 5.0, "ystrength": 5.0, "vibrato": 20.0, "randomness": 90.0, "fadeout": "false", "block": "true"}}, {"id": 215, "prop": "image", "attributes": {}}, {"id": 216, "prop": "charslot", "attributes": {}}, {"id": 217, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}